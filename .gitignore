# --- Python ---
.venv/
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.ruff_cache/
.mypy_cache/
*.egg-info/
build/
dist/

# --- IDE / OS ---
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp
*~

# --- Runtime data on aizh (regenerated by the pipeline; large; private) ---
# Local mirrors of the NAS source (~60 GB per subset)
source_local/
# Local restructured output (~60 GB per subset, eventually rsync'd to NAS)
target_local/
# Per-run intermediate CSVs / embeddings / extracted text
data/extracted_text/
data/*.npy
data/*.bin
data/*.csv
# Per-subset wizard state (machine-local; contains NAS folder names which may be private)
data/runs/

# --- KB stack runtime data ---
# Qdrant container data volumes (huge, regenerated from source by indexer)
qdrant_data/
# Per-variant per-root scan summaries (contain filename lists which may be private)
kb/data/

# --- Logs ---
logs/

# --- NAS mount point (just an empty dir on aizh; SSHFS mounts onto it) ---
nas/

# --- Secrets ---
.env
.env.*
# Template/example file is safe to commit:
!.env.example
*.pem
*.key
secrets/

# --- Misc ---
*.log
*.tmp
*.bak
