# Copy to .env and edit per host.
#
#   cp .env.example .env
#   docker compose up -d

# --- User UID / GID -----------------------------------------------------
# Files written to bind-mounted dirs (data/, target_local/, logs/) will
# be owned by this UID:GID. Set to your host user so the files look
# native:
#   echo "APP_UID=$(id -u)"
#   echo "APP_GID=$(id -g)"
APP_UID=1000
APP_GID=1000

# --- NAS mount on the host ----------------------------------------------
# The host mounts the NAS via SSHFS at this path (./kb.py mount). The
# chat + pipeline containers bind-mount it in as /app/nas (read-only).
NAS_MOUNT_HOST=${HOME}/nas

# --- HuggingFace cache --------------------------------------------------
# Where bge-m3 (~1.2 GB) is cached on the host. Bind-mounted into
# containers so the model isn't re-downloaded per build.
HF_CACHE_HOST=${HOME}/.cache/huggingface

# --- Qdrant data directories on the host --------------------------------
# Where Qdrant containers persist their vector store. Defaults match the
# pre-Docker layout used by the existing docker/qdrant/docker-compose.yml
# so existing data is preserved on migration.
QDRANT_DATA_PERSONAL=./qdrant_data_personal
QDRANT_DATA_360F=./qdrant_data_360f

# --- Cloudflare Tunnel --------------------------------------------------
# Tunnel name (created via `cloudflared tunnel login && cloudflared
# tunnel create folderreorg`). The credentials JSON + config.yml live
# at CLOUDFLARED_CONFIG_HOST/.
CLOUDFLARED_TUNNEL=folderreorg
CLOUDFLARED_CONFIG_HOST=${HOME}/.cloudflared
